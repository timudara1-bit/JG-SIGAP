{
    "prettier.arrowParens": "always",
    "prettier.bracketSameLine": true,
    "editor.defaultFormatter": "vscode.configuration-editing",
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingTemplateStringBraces": true,
    "js/ts.format.insertSpaceAfterTypeAssertion": true,
    "js/ts.format.insertSpaceBeforeFunctionParenthesis": true,
    "js/ts.format.placeOpenBraceOnNewLineForControlBlocks": true,
    "js/ts.format.insertSpaceBeforeAndAfterBinaryOperators": true
}